# ============================================================================
# Supabase (app — used by Vite dev server and production builds)
# ============================================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# This will enable live AH pricing in the Enhancement List modal.
# Leave unset in production until the feature is ready to ship.
VITE_SHOW_AUCTION_PRICES=false

# ============================================================================
# Admin / script-only env vars
# ============================================================================
# Used by scripts/bulk-import-mids.ts to bypass RLS and rate limiting.
# NEVER commit these. NEVER ship in client bundles.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
